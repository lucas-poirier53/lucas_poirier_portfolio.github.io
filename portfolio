<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Lucas Poirier — Portfolio</title>
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
  <style>
    :root {
      --bg: #0d0f14;
      --surface: #13161e;
      --surface2: #1a1e2a;
      --border: #232838;
      --accent: #4f8ef7;
      --accent2: #a78bfa;
      --accent3: #34d399;
      --text: #e8eaf0;
      --text-muted: #8891a8;
      --text-dim: #555e75;
      --mono: 'Space Mono', monospace;
      --sans: 'Space Grotesk', sans-serif;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: var(--sans);
      line-height: 1.65;
      min-height: 100vh;
    }

    /* ── NAV ─────────────────────────────────────────── */
    nav {
      position: sticky;
      top: 0;
      z-index: 100;
      background: rgba(13,15,20,0.92);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--border);
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 2rem;
      height: 58px;
    }
    .nav-logo {
      font-family: var(--mono);
      font-size: 0.85rem;
      color: var(--accent);
      letter-spacing: 0.04em;
      text-decoration: none;
    }
    .nav-links {
      display: flex;
      gap: 0.25rem;
      list-style: none;
    }
    .nav-links a {
      display: block;
      padding: 0.4rem 0.85rem;
      font-size: 0.82rem;
      font-weight: 500;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      color: var(--text-muted);
      text-decoration: none;
      border-radius: 6px;
      transition: color 0.18s, background 0.18s;
    }
    .nav-links a:hover, .nav-links a.active {
      color: var(--text);
      background: var(--surface2);
    }

    /* ── PAGES ───────────────────────────────────────── */
    .page { display: none; padding: 3rem 2rem 5rem; max-width: 900px; margin: 0 auto; }
    .page.active { display: block; }

    /* ── SECTION LABELS ──────────────────────────────── */
    .eyebrow {
      font-family: var(--mono);
      font-size: 0.7rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 0.6rem;
    }

    h1 {
      font-size: clamp(2rem, 5vw, 3.2rem);
      font-weight: 700;
      line-height: 1.1;
      letter-spacing: -0.02em;
      margin-bottom: 1.25rem;
    }
    h2 {
      font-size: 1.35rem;
      font-weight: 600;
      letter-spacing: -0.01em;
      margin-bottom: 0.5rem;
    }
    h3 {
      font-size: 1rem;
      font-weight: 600;
      color: var(--text);
    }

    p { color: var(--text-muted); margin-bottom: 0.9rem; }
    p:last-child { margin-bottom: 0; }

    a { color: var(--accent); text-decoration: none; }
    a:hover { text-decoration: underline; }

    /* ── HOME PAGE ───────────────────────────────────── */
    .hero {
      padding: 4rem 0 2rem;
      border-bottom: 1px solid var(--border);
      margin-bottom: 3rem;
    }
    .hero-tag {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      background: var(--surface2);
      border: 1px solid var(--border);
      border-radius: 100px;
      padding: 0.3rem 0.9rem;
      font-family: var(--mono);
      font-size: 0.72rem;
      color: var(--accent3);
      letter-spacing: 0.06em;
      margin-bottom: 1.5rem;
    }
    .hero-tag::before {
      content: '';
      width: 7px; height: 7px;
      border-radius: 50%;
      background: var(--accent3);
    }
    .hero p {
      font-size: 1.05rem;
      max-width: 600px;
      color: var(--text-muted);
      margin-bottom: 1rem;
    }
    .contact-line {
      margin-top: 2rem;
      display: flex;
      align-items: center;
      gap: 1.5rem;
      flex-wrap: wrap;
    }
    .contact-line a {
      font-family: var(--mono);
      font-size: 0.78rem;
      color: var(--text-muted);
      display: flex;
      align-items: center;
      gap: 0.4rem;
      transition: color 0.15s;
    }
    .contact-line a:hover { color: var(--text); text-decoration: none; }

    /* ── GRID CARDS ──────────────────────────────────── */
    .card-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      gap: 1rem;
      margin-top: 2rem;
    }
    .card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 1.4rem 1.5rem;
      cursor: pointer;
      transition: border-color 0.18s, transform 0.18s;
      text-decoration: none;
      display: block;
      color: inherit;
    }
    .card:hover {
      border-color: var(--accent);
      transform: translateY(-2px);
      text-decoration: none;
    }
    .card-icon {
      font-size: 1.5rem;
      margin-bottom: 0.8rem;
    }
    .card h3 { font-size: 0.95rem; margin-bottom: 0.35rem; }
    .card p { font-size: 0.82rem; color: var(--text-dim); margin: 0; }

    /* ── COMPÉTENCES ─────────────────────────────────── */
    .competence-block {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 1.75rem;
      margin-bottom: 1rem;
      position: relative;
      overflow: hidden;
    }
    .competence-block::before {
      content: '';
      position: absolute;
      left: 0; top: 0; bottom: 0;
      width: 3px;
      border-radius: 3px 0 0 3px;
    }
    .cb-traiter::before { background: var(--accent); }
    .cb-analyser::before { background: var(--accent2); }
    .cb-valoriser::before { background: var(--accent3); }
    .cb-modeliser::before { background: #fb923c; }

    .comp-title {
      font-size: 1.1rem;
      font-weight: 700;
      margin-bottom: 0.4rem;
    }
    .comp-subtitle {
      font-family: var(--mono);
      font-size: 0.72rem;
      color: var(--text-dim);
      letter-spacing: 0.08em;
      text-transform: uppercase;
      margin-bottom: 0.8rem;
    }
    .comp-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 0.4rem;
      margin-top: 1rem;
    }
    .tag {
      background: var(--surface2);
      border: 1px solid var(--border);
      border-radius: 6px;
      padding: 0.2rem 0.6rem;
      font-size: 0.72rem;
      font-family: var(--mono);
      color: var(--text-muted);
    }

    /* ── PROJETS ─────────────────────────────────────── */
    .projet-item {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 1.6rem;
      margin-bottom: 1rem;
      transition: border-color 0.18s;
    }
    .projet-item:hover { border-color: var(--accent2); }

    .projet-header {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 1rem;
      margin-bottom: 0.75rem;
      flex-wrap: wrap;
    }
    .projet-num {
      font-family: var(--mono);
      font-size: 0.68rem;
      color: var(--text-dim);
      letter-spacing: 0.1em;
      text-transform: uppercase;
      margin-bottom: 0.3rem;
    }
    .projet-links { display: flex; gap: 0.5rem; flex-shrink: 0; }
    .btn-link {
      display: inline-flex;
      align-items: center;
      gap: 0.35rem;
      background: var(--surface2);
      border: 1px solid var(--border);
      border-radius: 7px;
      padding: 0.3rem 0.75rem;
      font-size: 0.75rem;
      font-family: var(--mono);
      color: var(--text-muted);
      text-decoration: none;
      transition: color 0.15s, border-color 0.15s;
    }
    .btn-link:hover { color: var(--text); border-color: var(--accent); text-decoration: none; }

    .skill-badges {
      display: flex;
      flex-wrap: wrap;
      gap: 0.4rem;
      margin-top: 0.8rem;
    }
    .badge {
      background: rgba(79,142,247,0.1);
      border: 1px solid rgba(79,142,247,0.25);
      border-radius: 5px;
      padding: 0.18rem 0.55rem;
      font-size: 0.7rem;
      font-family: var(--mono);
      color: var(--accent);
    }
    .badge.purple {
      background: rgba(167,139,250,0.1);
      border-color: rgba(167,139,250,0.25);
      color: var(--accent2);
    }
    .badge.green {
      background: rgba(52,211,153,0.1);
      border-color: rgba(52,211,153,0.25);
      color: var(--accent3);
    }
    .badge.orange {
      background: rgba(251,146,60,0.1);
      border-color: rgba(251,146,60,0.25);
      color: #fb923c;
    }

    /* ── LOGICIELS ───────────────────────────────────── */
    .logiciel-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
      gap: 0.8rem;
      margin-top: 1.5rem;
    }
    .logiciel-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 1.1rem 1.2rem;
    }
    .logiciel-name {
      font-weight: 600;
      font-size: 0.9rem;
      margin-bottom: 0.2rem;
    }
    .logiciel-level {
      font-family: var(--mono);
      font-size: 0.65rem;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      margin-bottom: 0.6rem;
    }
    .level-bar {
      height: 3px;
      border-radius: 3px;
      background: var(--border);
      overflow: hidden;
    }
    .level-fill {
      height: 100%;
      border-radius: 3px;
      background: linear-gradient(90deg, var(--accent), var(--accent2));
    }

    /* ── ALTERNANCE ──────────────────────────────────── */
    .stage-header {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 1.75rem;
      margin-bottom: 1.5rem;
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 1rem;
      flex-wrap: wrap;
    }
    .stage-company {
      font-size: 1.4rem;
      font-weight: 700;
      margin-bottom: 0.2rem;
    }
    .stage-meta {
      font-family: var(--mono);
      font-size: 0.72rem;
      color: var(--text-dim);
      letter-spacing: 0.06em;
    }
    .stage-badge {
      background: rgba(52,211,153,0.15);
      border: 1px solid rgba(52,211,153,0.3);
      border-radius: 8px;
      padding: 0.4rem 1rem;
      font-family: var(--mono);
      font-size: 0.72rem;
      color: var(--accent3);
      text-align: center;
      white-space: nowrap;
    }

    .section-block {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 1.5rem;
      margin-bottom: 1rem;
    }
    .section-block h3 {
      font-size: 0.95rem;
      margin-bottom: 0.6rem;
      color: var(--accent);
    }

    .db-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1rem;
      margin-top: 1rem;
    }
    @media (max-width: 600px) {
      .db-grid { grid-template-columns: 1fr; }
      .card-grid { grid-template-columns: 1fr; }
    }
    .db-card {
      background: var(--surface2);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 1.2rem;
    }
    .db-card-title {
      font-weight: 600;
      font-size: 0.9rem;
      margin-bottom: 0.5rem;
    }
    .db-card p { font-size: 0.8rem; color: var(--text-dim); }

    /* ── DIVIDER ─────────────────────────────────────── */
    .divider {
      height: 1px;
      background: var(--border);
      margin: 2.5rem 0;
    }

    /* ── FOOTER ──────────────────────────────────────── */
    footer {
      text-align: center;
      padding: 2rem;
      border-top: 1px solid var(--border);
      font-family: var(--mono);
      font-size: 0.7rem;
      color: var(--text-dim);
    }
  </style>
</head>
